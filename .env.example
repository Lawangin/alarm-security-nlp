# ─── NLP Strategy ────────────────────────────────────────────────────────────
# Options: rule-based | llm | hybrid
NLP_STRATEGY=hybrid

# ─── LLM Settings ────────────────────────────────────────────────────────────
# Required when NLP_STRATEGY is "llm" or "hybrid"
# Get your key at https://console.anthropic.com
LLM_API_KEY=

# Model to use for LLM calls (claude-haiku-4-5 is cheapest and sufficient)
LLM_MODEL=claude-haiku-4-5

# Confidence below this threshold triggers LLM escalation in hybrid mode (0–1)
CONFIDENCE_THRESHOLD=0.85

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development
LOG_LEVEL=info

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000
